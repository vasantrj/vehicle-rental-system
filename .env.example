# ============================================================
# DriveEase — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub — it is in .gitignore.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=vehicle_rental

# ── Razorpay (get keys from https://dashboard.razorpay.com/app/keys)
# Use rzp_test_... for testing, rzp_live_... for production
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Email (Gmail SMTP with App Password)
# How to get App Password: https://myaccount.google.com/apppasswords
# For better deliverability on shared hosting, use Brevo free SMTP:
#   MAIL_HOST=smtp-relay.brevo.com
#   MAIL_PORT=587
#   MAIL_USERNAME=your_brevo_login@email.com
#   MAIL_PASSWORD=your_brevo_smtp_key
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME=DriveEase